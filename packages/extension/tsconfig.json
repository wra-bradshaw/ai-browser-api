{
  "extends": "../../tsconfig.options.json",
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "jsx": "react-jsx",
    "isolatedModules": true,
    "allowJs": false,
    "noEmit": true,
    "paths": {
      "@": ["./src"],
      "@/*": ["./src/*"],
      "@@": ["."],
      "@@/*": ["./*"],
      "~": ["./src"],
      "~/*": ["./src/*"],
      "~~": ["."],
      "~~/*": ["./*"]
    },
    "tsBuildInfoFile": "./.tsbuild/tsconfig.tsbuildinfo"
  },
  "include": [
    ".wxt/wxt.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "scripts/**/*.ts",
    "web-ext.config.ts",
    "wxt.config.ts"
  ],
  "exclude": ["node_modules", ".output"],
  "references": [
    {
      "path": "../bridge-codecs"
    },
    {
      "path": "../contracts"
    },
    {
      "path": "../effect-utils"
    },
    {
      "path": "../reactive-core"
    },
    {
      "path": "../runtime-core"
    }
  ]
}
