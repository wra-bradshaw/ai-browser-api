{
  "extends": "../../tsconfig.options.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "noEmit": true,
    "tsBuildInfoFile": "./.tsbuild/tsconfig.tsbuildinfo",
    "useDefineForClassFields": true,
    "allowJs": false,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "references": [
    {
      "path": "../client-react"
    }
  ]
}
