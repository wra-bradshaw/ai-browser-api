{
  "name": "ai-browser-api",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:extension": "moon run extension:dev",
    "dev:example": "moon run example-app:dev",
    "dev:all": "moon run extension:dev example-app:dev",
    "build": "moon run :build",
    "sync": "moon sync",
    "zip": "moon run extension:zip",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "moon run :typecheck",
    "lint": "moon run :lint",
    "knip": "knip"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.4.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "knip": "^5.86.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.1.0"
  }
}
